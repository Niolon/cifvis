#\#CIF_2.0

# Minimal original CIF2 test structure (fictitious cubic cell) exercising the
# CIF2 parsing path end-to-end through CrystalStructure.fromCIF.
data_cif2_structure

_cell_length_a      5.6402(3)
_cell_length_b      5.6402(3)
_cell_length_c      5.6402(3)
_cell_angle_alpha   90.0
_cell_angle_beta    90.0
_cell_angle_gamma   90.0
_cell_volume        179.43(2)

_space_group_crystal_system  cubic
_space_group_IT_number       225
_space_group_name_H-M_alt    'F m -3 m'

loop_
  _space_group_symop_id
  _space_group_symop_operation_xyz
